extends layout

block content
  img(id="header-logo", src=dark_bg_logo)

  img#menu-btn(src=dropdown, alt="Open Menu", style="cursor: pointer;")

  #my-sidebar.sidebar
    a(href="/") Home Page
    a(href="/menu") Our Menu
    a(href="/about") About Us
    a(href="/reviews") Leave a Review

  -
    var menuItems = [
      {name: 'Maple Bacon', img: 'https://www.thespruceeats.com/thmb/s_nLo-fq7txaKZ-SC96_m94JjhY=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/MapleBaconDonutHERO-318c27bf6f3a4449847447cdbe2cd5e4.jpg'},
      {name: 'Vanilla Chocolate Chip', img: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSrZLEukRi6hA_wHroUCSYYJnfnBciGCUXRXQ&s'},
      {name: 'Vanilla Rainbow', img: 'data:image/jpeg;base64,'},
      {name: 'Caramel Seasalt', img: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRCpMKsOh2myW0OIFmVjZE0ofb-06HE3ezppw&s'},
      {name: 'Caramel Reeses Pieces', img: 'https://www.worldbakers.com/wp-content/uploads/reeses-doughnut-750x400.jpg'},
      {name: 'Vanilla Raspberry', img: 'https://theloopywhisk.com/wp-content/uploads/2023/06/Gluten-Free-Raspberry-Doughnuts_730px-2.jpg.webp'},
      {name: 'Vanilla Oreo', img: 'https://www.bakeandbacon.com/wp-content/uploads/2023/04/oreo-donuts-7.jpg'},
      {name: 'Chocolate Candy Bar', img: 'https://blogger.googleusercontent.com/img/a/AVvXsEg8Z7aOVyp4zFiiL7TFQpw22eb5afTvSHAb4a5Fo4kjHczzHO4KORmCdumYWsDewwoU-0JgW2j6vJzO8yO7xUsXUk9f5hxcHKCo4N-I-1YGxisx5_dEZsh6m0SNbmV4yK4fjFdcrz7_8lvDTt93CRVab_Iwm48p3NyLPHAGTzi8qbnnAmZCuCkiU0Iq=w640-h480'},
      {name: 'Double Chocolate Sprinkles', img: 'https://www.thebakingchocolatess.com/wp-content/uploads/2022/09/cinnamonrollblondies-25.jpg'},
      {name: 'Signature Frpppucino', img: 'https://i0.wp.com/binjalsvegkitchen.com/wp-content/uploads/2015/10/Homemade-Frappuccino-H1.jpg?fit=300%2C450&ssl=1'}
    ]

  .menu-container
    h1.menu-heading Our Menu
    
    .menu-grid
      each item in menuItems
        a.menu-card(href=item.url)
          .card-image-wrapper
            img(src=item.img, alt=item.name)
          .card-info
            span.card-title= item.name
            span.card-action View More

block scripts
  script(src="/javascripts/sidemenu.js")
